<Window x:Class="SoundMixer.App.Views.ClipSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки звука"
        Width="380" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackground}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Эмодзи + Название -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,12">
            <Button x:Name="EmojiButton" FontSize="48"
                    HorizontalAlignment="Center" Cursor="Hand"
                    Click="PickEmoji_Click"
                    ToolTip="Нажмите чтобы сменить">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{DynamicResource EmojiButtonBackground}"
                                CornerRadius="16" Width="80" Height="80">
                            <TextBlock x:Name="EmojiText" Text="{Binding Emoji}"
                                       FontSize="40" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- Настройки -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название:" Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                <TextBox x:Name="NameInput" FontSize="13" Margin="0,4,0,12"
                         Background="{DynamicResource InputBackground}"
                         Foreground="{DynamicResource TextPrimary}" Padding="6,4" />

                <TextBlock Text="Громкость:" Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                    <Slider x:Name="VolumeSlider" Width="250" Minimum="0" Maximum="2"
                            SmallChange="0.05" VerticalAlignment="Center" />
                    <TextBlock x:Name="VolumeLabel" Foreground="{DynamicResource TextPrimary}"
                               FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <CheckBox x:Name="LoopCheck" Content="Зацикливать"
                          Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12" />

                <TextBlock Text="Горячая клавиша:" Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                    <TextBox x:Name="HotKeyBox" Width="180" FontSize="12" IsReadOnly="True"
                             Background="{DynamicResource InputBackground}"
                             Foreground="{DynamicResource TextPrimary}" Padding="6,4"
                             GotFocus="HotKeyBox_GotFocus"
                             PreviewKeyDown="HotKeyBox_PreviewKeyDown"
                             ToolTip="Кликните и нажмите комбинацию" />
                    <Button Content="Очистить" Click="ClearHotKey_Click"
                            Style="{StaticResource ModernButton}"
                            Background="{DynamicResource ToolButtonBackground}"
                            Padding="8,4" FontSize="11" Margin="8,0,0,0" />
                </StackPanel>

                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,4,0,12" />

                <!-- Обрезка и экспорт -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="✂️ Обрезать" Click="Trim_Click"
                            Style="{StaticResource ModernButton}"
                            Background="{DynamicResource ToolButtonBackground}" Margin="0,0,8,0" />
                    <Button Content="💾 Экспортировать" Click="Export_Click"
                            Style="{StaticResource ModernButton}"
                            Background="{DynamicResource ToolButtonBackground}" />
                </StackPanel>

                <TextBlock x:Name="TrimInfoText" Foreground="#FFEEAA00" FontSize="11" Margin="0,4,0,8" />

                <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,4,0,12" />

                <Button Content="🗑 Удалить звук" Click="Delete_Click"
                        Style="{StaticResource DangerButton}"
                        HorizontalAlignment="Left" />
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Отмена" Click="Cancel_Click"
                    Style="{StaticResource ModernButton}"
                    Background="{DynamicResource ToolButtonBackground}" Margin="4,0" />
            <Button Content="Сохранить" Click="Save_Click"
                    Style="{StaticResource PlayButton}" Margin="4,0" />
        </StackPanel>
    </Grid>
</Window>