<Window x:Class="SoundMixer.App.Views.TrimEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обрезка клипа"
        Width="700" Height="350"
        MinWidth="500" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackground}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" />
            <TextBlock x:Name="DurationText" FontSize="12"
                       Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Waveform + маркеры обрезки -->
        <Border Grid.Row="1" Background="{DynamicResource InputBackground}" 
                CornerRadius="6" ClipToBounds="True">
            <Grid x:Name="WaveformGrid">
                <!-- Waveform canvas -->
                <Canvas x:Name="WaveformCanvas" />

                <!-- Затемнение обрезанных участков -->
                <Canvas x:Name="TrimOverlayCanvas" />

                <!-- Левый маркер -->
                <Thumb x:Name="LeftThumb" Width="12" HorizontalAlignment="Left"
                       VerticalAlignment="Stretch" Cursor="SizeWE"
                       DragDelta="LeftThumb_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="#CC00AAFF" CornerRadius="3,0,0,3"
                                    BorderBrush="#00AAFF" BorderThickness="1">
                                <TextBlock Text="◀" Foreground="White" FontSize="8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <!-- Правый маркер -->
                <Thumb x:Name="RightThumb" Width="12" HorizontalAlignment="Right"
                       VerticalAlignment="Stretch" Cursor="SizeWE"
                       DragDelta="RightThumb_DragDelta">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="#CCFF6B6B" CornerRadius="0,3,3,0"
                                    BorderBrush="#FF6B6B" BorderThickness="1">
                                <TextBlock Text="▶" Foreground="White" FontSize="8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Border>

        <!-- Информация о позициях -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="StartTimeText"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12" />
            <TextBlock Grid.Column="1" x:Name="TrimmedDurationText"
                       Foreground="{DynamicResource TextPrimary}" FontSize="12"
                       HorizontalAlignment="Center" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" x:Name="EndTimeText"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                       HorizontalAlignment="Right" />
        </Grid>

        <!-- Точный ввод -->
        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="100" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Начало (сек):" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" x:Name="StartInput" FontSize="12"
                     TextChanged="StartInput_TextChanged"
                     Background="{DynamicResource InputBackground}"
                     Foreground="{DynamicResource TextPrimary}" Padding="4" />

            <TextBlock Grid.Column="3" Text="Конец (сек):" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,8,0" />
            <TextBox Grid.Column="4" x:Name="EndInput" FontSize="12"
                     TextChanged="EndInput_TextChanged"
                     Background="{DynamicResource InputBackground}"
                     Foreground="{DynamicResource TextPrimary}" Padding="4" />
        </Grid>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Сбросить обрезку" Click="Reset_Click"
                    Style="{StaticResource ModernButton}" Margin="4,0"
                    Background="{DynamicResource ToolButtonBackground}" />
            <Button Content="Отмена" Click="Cancel_Click"
                    Style="{StaticResource ModernButton}" Margin="4,0"
                    Background="{DynamicResource ToolButtonBackground}" />
            <Button Content="Применить" Click="Apply_Click"
                    Style="{StaticResource PlayButton}" Margin="4,0" />
        </StackPanel>
    </Grid>
</Window>