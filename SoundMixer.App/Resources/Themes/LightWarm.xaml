<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="WindowBackground" Color="#FFFFF8F0" />
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="InputBackground" Color="#FFF5EDE0" />
    <SolidColorBrush x:Key="BorderColor" Color="#FFE8DDD0" />
    <SolidColorBrush x:Key="ComboBoxBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="#FF3E2723" />
    <SolidColorBrush x:Key="ComboBoxDropdownBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ComboBoxHoverBackground" Color="#FFFFF0D0" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="#FFFF9800" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FFF57C00" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FFE53935" />

    <SolidColorBrush x:Key="TextPrimary" Color="#FF3E2723" />
    <SolidColorBrush x:Key="TextSecondary" Color="#FF795548" />
    <SolidColorBrush x:Key="TextMuted" Color="#FFA1887F" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="LevelBarBackground" Color="#FFE8DDD0" />
    <SolidColorBrush x:Key="LevelBarInput" Color="#FFFF9800" />
    <SolidColorBrush x:Key="LevelBarOutput" Color="#FFF57C00" />

    <SolidColorBrush x:Key="EmojiButtonBackground" Color="#11000000" />
    <SolidColorBrush x:Key="ToolButtonBackground" Color="#FFF5EDE0" />
    <SolidColorBrush x:Key="DeleteButtonBackground" Color="#22E53935" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#FFE8DDD0" />
    <SolidColorBrush x:Key="ClipPlayingBrush" Color="#FFFF9800" />
    <SolidColorBrush x:Key="ClipStoppedBrush" Color="#FFF57C00" />

    <SolidColorBrush x:Key="ScrollBarBackground" Color="#FFFFF8F0" />
    <SolidColorBrush x:Key="ScrollBarThumb" Color="#FFD7CFC0" />

    <system:String x:Key="ThemeName">Light Warm</system:String>
</ResourceDictionary>