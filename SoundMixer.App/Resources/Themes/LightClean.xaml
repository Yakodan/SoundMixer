<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="WindowBackground" Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="InputBackground" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="BorderColor" Color="#FFE0E0E0" />
    <SolidColorBrush x:Key="ComboBoxBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="#FF212121" />
    <SolidColorBrush x:Key="ComboBoxDropdownBackground" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ComboBoxHoverBackground" Color="#FFE3F2FD" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF2196F3" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF1976D2" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FFF44336" />

    <SolidColorBrush x:Key="TextPrimary" Color="#FF212121" />
    <SolidColorBrush x:Key="TextSecondary" Color="#FF757575" />
    <SolidColorBrush x:Key="TextMuted" Color="#FF9E9E9E" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="LevelBarBackground" Color="#FFE0E0E0" />
    <SolidColorBrush x:Key="LevelBarInput" Color="#FF4CAF50" />
    <SolidColorBrush x:Key="LevelBarOutput" Color="#FF2196F3" />

    <SolidColorBrush x:Key="EmojiButtonBackground" Color="#11000000" />
    <SolidColorBrush x:Key="ToolButtonBackground" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="DeleteButtonBackground" Color="#22F44336" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#FFE0E0E0" />
    <SolidColorBrush x:Key="ClipPlayingBrush" Color="#FF4CAF50" />
    <SolidColorBrush x:Key="ClipStoppedBrush" Color="#FF2196F3" />

    <SolidColorBrush x:Key="ScrollBarBackground" Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="ScrollBarThumb" Color="#FFBDBDBD" />

    <system:String x:Key="ThemeName">Light Clean</system:String>
</ResourceDictionary>