<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <SolidColorBrush x:Key="WindowBackground" Color="#FF1A1A1A" />
    <SolidColorBrush x:Key="PanelBackground" Color="#FF252525" />
    <SolidColorBrush x:Key="CardBackground" Color="#FF252525" />
    <SolidColorBrush x:Key="InputBackground" Color="#FF333333" />
    <SolidColorBrush x:Key="BorderColor" Color="#FF404040" />
    <SolidColorBrush x:Key="ComboBoxBackground" Color="#FF333333" />
    <SolidColorBrush x:Key="ComboBoxForeground" Color="#FFFAFAFA" />
    <SolidColorBrush x:Key="ComboBoxDropdownBackground" Color="#FF252525" />
    <SolidColorBrush x:Key="ComboBoxHoverBackground" Color="#FF3D5040" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF4CAF50" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF2E7D32" />
    <SolidColorBrush x:Key="DangerBrush" Color="#FFF44336" />

    <SolidColorBrush x:Key="TextPrimary" Color="#FFFAFAFA" />
    <SolidColorBrush x:Key="TextSecondary" Color="#FFBDBDBD" />
    <SolidColorBrush x:Key="TextMuted" Color="#FF757575" />
    <SolidColorBrush x:Key="TextOnAccent" Color="#FFFFFFFF" />

    <SolidColorBrush x:Key="LevelBarBackground" Color="#FF121212" />
    <SolidColorBrush x:Key="LevelBarInput" Color="#FF4CAF50" />
    <SolidColorBrush x:Key="LevelBarOutput" Color="#FF2E7D32" />

    <SolidColorBrush x:Key="EmojiButtonBackground" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="ToolButtonBackground" Color="#FF252525" />
    <SolidColorBrush x:Key="DeleteButtonBackground" Color="#44F44336" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#FF404040" />
    <SolidColorBrush x:Key="ClipPlayingBrush" Color="#FF4CAF50" />
    <SolidColorBrush x:Key="ClipStoppedBrush" Color="#FF2E7D32" />

    <SolidColorBrush x:Key="ScrollBarBackground" Color="#FF1A1A1A" />
    <SolidColorBrush x:Key="ScrollBarThumb" Color="#FF404040" />

    <system:String x:Key="ThemeName">Dark Green</system:String>
</ResourceDictionary>