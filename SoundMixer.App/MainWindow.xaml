<Window x:Class="SoundMixer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SoundMixer.App.Converters"
        xmlns:helpers="clr-namespace:SoundMixer.App.Helpers"
        Title="🎙 SoundMixer Pro"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource WindowBackground}"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/Icons/app.ico">

    <Window.Resources>
        <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
        <converters:LevelToWidthConverter x:Key="LevelToWidthConverter" />
        <converters:BoolToVisibilityTrueConverter x:Key="BoolToVisTrue" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <converters:PlayingToColorConverter x:Key="PlayingToColor" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ВЕРХНЯЯ ПАНЕЛЬ -->
        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎙 SoundMixer Pro" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center" Margin="0,0,20,0" />
                    <Button Content="{Binding StartStopButtonText}"
                            Command="{Binding StartStopCommand}"
                            Style="{StaticResource PlayButton}"
                            FontSize="14" Padding="20,8" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Селектор темы -->
                    <ComboBox ItemsSource="{Binding AvailableThemes}"
                        SelectedItem="{Binding SelectedTheme}"
                        DisplayMemberPath=""
                        Width="150" Margin="4,0"
                        Style="{StaticResource ModernComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                    FontFamily="Segoe UI, Segoe UI Emoji, Segoe UI Symbol" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="🔄" Command="{Binding RefreshDevicesCommand}"
                            Style="{StaticResource ModernButton}" Margin="4,0" ToolTip="Обновить устройства" />
                    <Button Content="💾" Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource ModernButton}" Margin="4,0" ToolTip="Сохранить настройки" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4">

                    <GroupBox Header="🔊 Устройства" Style="{StaticResource ModernGroupBox}">
                        <StackPanel>
                            <TextBlock Text="Микрофон:" Style="{StaticResource ModernLabel}" />
                            <ComboBox ItemsSource="{Binding InputDevices}"
                                      SelectedItem="{Binding SelectedInputDevice}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}" Margin="0,2,0,8" />

                            <TextBlock Text="Виртуальный кабель:" Style="{StaticResource ModernLabel}" />
                            <ComboBox ItemsSource="{Binding VirtualCableDevices}"
                                      SelectedItem="{Binding SelectedVirtualCable}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}" Margin="0,2,0,8" />

                            <TextBlock Text="Наушники (мониторинг):" Style="{StaticResource ModernLabel}" />
                            <ComboBox ItemsSource="{Binding OutputDevices}"
                                      SelectedItem="{Binding SelectedOutputDevice}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource ModernComboBox}" Margin="0,2,0,4" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="📊 Уровни" Style="{StaticResource ModernGroupBox}">
                        <StackPanel>
                            <TextBlock Text="Вход:" Style="{StaticResource ModernLabel}" />
                            <Border Background="{DynamicResource LevelBarBackground}" CornerRadius="3" Height="8" Margin="0,2,0,6">
                                <Border Background="{DynamicResource LevelBarInput}" CornerRadius="3" HorizontalAlignment="Left"
                                        Width="{Binding InputLevel, Converter={StaticResource LevelToWidthConverter}, ConverterParameter=280}" />
                            </Border>
                            <TextBlock Text="Выход:" Style="{StaticResource ModernLabel}" />
                            <Border Background="{DynamicResource LevelBarBackground}" CornerRadius="3" Height="8" Margin="0,2,0,6">
                                <Border Background="{DynamicResource LevelBarOutput}" CornerRadius="3" HorizontalAlignment="Left"
                                        Width="{Binding OutputLevel, Converter={StaticResource LevelToWidthConverter}, ConverterParameter=280}" />
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="🎚 Громкость и Мониторинг" Style="{StaticResource ModernGroupBox}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource ModernLabel}">
                                <Run Text="Микрофон: " /><Run Text="{Binding MicrophoneVolume, StringFormat='{}{0:P0}'}" />
                            </TextBlock>
                            <Slider Value="{Binding MicrophoneVolume}" Minimum="0" Maximum="2" Style="{StaticResource ModernSlider}" Margin="0,2,0,8" />

                            <TextBlock Style="{StaticResource ModernLabel}">
                                <Run Text="Soundboard: " /><Run Text="{Binding SoundboardVolume, StringFormat='{}{0:P0}'}" />
                            </TextBlock>
                            <Slider Value="{Binding SoundboardVolume}" Minimum="0" Maximum="2" Style="{StaticResource ModernSlider}" Margin="0,2,0,8" />

                            <Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,4,0,8" />

                            <CheckBox Content="🎧 Включить мониторинг" IsChecked="{Binding MonitorEnabled}"
                                      Style="{StaticResource ModernCheckBox}" FontWeight="Bold" />
                            <StackPanel Margin="24,4,0,0">
                                <CheckBox Content="🎙 Слышать свой микрофон" IsChecked="{Binding MonitorMicrophone}" Style="{StaticResource ModernCheckBox}" />
                                <CheckBox Content="🔊 Слышать звуки soundboard" IsChecked="{Binding MonitorSoundboard}" Style="{StaticResource ModernCheckBox}" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource ModernLabel}" Margin="0,8,0,0">
                                <Run Text="Громкость мониторинга: " /><Run Text="{Binding MonitorVolume, StringFormat='{}{0:P0}'}" />
                            </TextBlock>
                            <Slider Value="{Binding MonitorVolume}" Minimum="0" Maximum="1" Style="{StaticResource ModernSlider}" Margin="0,2,0,4" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="🔇 Noise Gate" Style="{StaticResource ModernGroupBox}">
                        <StackPanel>
                            <CheckBox Content="Включить" IsChecked="{Binding NoiseGateEnabled}" Style="{StaticResource ModernCheckBox}" />
                            <TextBlock Style="{StaticResource ModernLabel}">
                                <Run Text="Порог: " /><Run Text="{Binding NoiseGateThreshold, StringFormat='{}{0:F0} дБ'}" />
                            </TextBlock>
                            <Slider Value="{Binding NoiseGateThreshold}" Minimum="-60" Maximum="-10" Style="{StaticResource ModernSlider}" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="🔨 Компрессор" Style="{StaticResource ModernGroupBox}">
                        <StackPanel>
                            <CheckBox Content="Включить" IsChecked="{Binding CompressorEnabled}" Style="{StaticResource ModernCheckBox}" />
                            <TextBlock Style="{StaticResource ModernLabel}">
                                <Run Text="Порог: " /><Run Text="{Binding CompressorThreshold, StringFormat='{}{0:F0} дБ'}" />
                            </TextBlock>
                            <Slider Value="{Binding CompressorThreshold}" Minimum="-50" Maximum="0" Style="{StaticResource ModernSlider}" Margin="0,2,0,6" />
                            <TextBlock Style="{StaticResource ModernLabel}">
                                <Run Text="Ratio: " /><Run Text="{Binding CompressorRatio, StringFormat='{}{0:F1}:1'}" />
                            </TextBlock>
                            <Slider Value="{Binding CompressorRatio}" Minimum="1" Maximum="20" Style="{StaticResource ModernSlider}" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="🎛 Эквалайзер" Style="{StaticResource ModernGroupBox}">
                        <ItemsControl ItemsSource="{Binding EqualizerBands}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Value="{Binding GainDb}" Minimum="-15" Maximum="15" Style="{StaticResource ModernSlider}" />
                                        <TextBlock Grid.Column="2" Text="{Binding GainDb, StringFormat='{}{0:+0.0;-0.0;0}'}" Foreground="{DynamicResource TextSecondary}" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <!-- ПРАВАЯ ПАНЕЛЬ: SOUNDBOARD -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Soundboard" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,16,0" />
                        <Button Content="+ Добавить" Command="{Binding AddSoundClipCommand}"
                    Style="{StaticResource ModernButton}" Margin="4,0" />
                        <Button Content="Stop All" Command="{Binding StopAllClipsCommand}"
                    Style="{StaticResource DangerButton}" Margin="4,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      AllowDrop="True"
                      Drop="SoundboardPanel_Drop"
                      DragOver="SoundboardPanel_DragOver">
                        <ItemsControl x:Name="SoundClipsList" ItemsSource="{Binding SoundClips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel x:Name="SoundClipsWrapPanel" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="130" Height="160" Margin="4" CornerRadius="10" Padding="8"
                                Background="{Binding IsPlaying, Converter={StaticResource PlayingToColor}}"
                                MouseMove="Card_MouseMove"
                                Tag="{Binding}">

                                        <Grid>
                                            <!-- Кнопка настроек в углу -->
                                            <Button Content="⚙" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-2,-2,0"
                                        Click="OpenClipSettings_Click" Tag="{Binding}"
                                        Cursor="Hand" FontSize="12" Opacity="0.6">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent" Padding="4,2">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Opacity" Value="1" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <StackPanel VerticalAlignment="Center">
                                                <!-- Эмодзи-кнопка -->
                                                <Button Command="{Binding DataContext.PlayClipCommand,
                                                     RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"
                                            Cursor="Hand" HorizontalAlignment="Center" Margin="0,0,0,6">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{DynamicResource EmojiButtonBackground}"
                                                        CornerRadius="14" Width="64" Height="64">
                                                                <TextBlock Text="{Binding Emoji}" FontSize="32"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Opacity" Value="0.8" />
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter Property="Opacity" Value="0.6" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Название -->
                                                <TextBlock Text="{Binding EffectiveName}"
                                               Foreground="{DynamicResource TextOnAccent}"
                                               FontSize="11" FontWeight="SemiBold"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="32" />

                                                <!-- Инфо -->
                                                <TextBlock Foreground="{DynamicResource TextOnAccent}" Opacity="0.6"
                                               FontSize="9" TextAlignment="Center">
                                        <Run Text="{Binding Duration, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="11">
                <Run Text="Storage: " /><Run Text="{Binding StorageSize, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- СТАТУС БАР -->
        <Border Grid.Row="2" Background="{DynamicResource PanelBackground}" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="8,0"
                             Fill="{Binding IsRunning, Converter={StaticResource BoolToColorConverter}}" />
                    <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" VerticalAlignment="Center"
                               Text="{Binding IsRunning, StringFormat='Активно: {0}'}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>